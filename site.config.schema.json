{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./site.config.schema.json",
  "title": "Portfolio Site Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["person", "seo", "theme", "ui", "sections"],
  "properties": {
    "person": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "location",
        "availability",
        "intro",
        "mission",
        "email",
        "brandMark",
        "socialLinks"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "fullName": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "availability": { "type": "string", "minLength": 1 },
        "intro": { "type": "string", "minLength": 1 },
        "mission": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "format": "email" },
        "brandMark": { "type": "string", "minLength": 1, "maxLength": 4 },
        "socialLinks": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    },
    "seo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "siteUrl": {
          "anyOf": [
            { "type": "string", "format": "uri" },
            { "type": "string", "const": "" }
          ]
        }
      }
    },
    "theme": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fonts", "palette"],
      "properties": {
        "fonts": {
          "type": "object",
          "additionalProperties": false,
          "required": ["body", "display"],
          "properties": {
            "body": { "type": "string", "minLength": 1 },
            "display": { "type": "string", "minLength": 1 }
          }
        },
        "palette": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "background",
            "backgroundStrong",
            "surface",
            "surfaceStrong",
            "text",
            "textMuted",
            "border",
            "borderStrong",
            "accent",
            "inverse"
          ],
          "properties": {
            "background": { "type": "string", "minLength": 1 },
            "backgroundStrong": { "type": "string", "minLength": 1 },
            "surface": { "type": "string", "minLength": 1 },
            "surfaceStrong": { "type": "string", "minLength": 1 },
            "text": { "type": "string", "minLength": 1 },
            "textMuted": { "type": "string", "minLength": 1 },
            "border": { "type": "string", "minLength": 1 },
            "borderStrong": { "type": "string", "minLength": 1 },
            "accent": { "type": "string", "minLength": 1 },
            "inverse": { "type": "string", "minLength": 1 }
          }
        },
        "themeColor": { "type": "string", "minLength": 1 }
      }
    },
    "ui": {
      "type": "object",
      "additionalProperties": false,
      "required": ["footer"],
      "properties": {
        "footer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["contactHeading", "profilesHeading"],
          "properties": {
            "contactHeading": { "type": "string", "minLength": 1 },
            "profilesHeading": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/homeSection" },
          { "$ref": "#/$defs/projectsSection" },
          { "$ref": "#/$defs/experienceSection" },
          { "$ref": "#/$defs/interestsSection" }
        ]
      }
    }
  },
  "$defs": {
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "href", "external"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "href": { "type": "string", "minLength": 1 },
        "external": { "type": "boolean" },
        "localized": { "type": "boolean" }
      }
    },
    "stat": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "value", "detail"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 },
        "detail": { "type": "string", "minLength": 1 }
      }
    },
    "principle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "body"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "body": { "type": "string", "minLength": 1 }
      }
    },
    "pageIntro": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eyebrow", "title", "description"],
      "properties": {
        "eyebrow": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "sectionHeading": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eyebrow", "title"],
      "properties": {
        "eyebrow": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "homeCard": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eyebrow", "title", "description"],
      "properties": {
        "eyebrow": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "projectInteraction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eyebrow",
        "title",
        "description",
        "searchLabel",
        "searchPlaceholder",
        "statusToolbarLabel",
        "statusLabels",
        "resultsPrefix",
        "resultNounSingular",
        "resultNounPlural"
      ],
      "properties": {
        "eyebrow": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "searchLabel": { "type": "string", "minLength": 1 },
        "searchPlaceholder": { "type": "string", "minLength": 1 },
        "statusToolbarLabel": { "type": "string", "minLength": 1 },
        "statusLabels": {
          "type": "object",
          "additionalProperties": false,
          "required": ["all", "featured", "live", "exploration"],
          "properties": {
            "all": { "type": "string", "minLength": 1 },
            "featured": { "type": "string", "minLength": 1 },
            "live": { "type": "string", "minLength": 1 },
            "exploration": { "type": "string", "minLength": 1 }
          }
        },
        "resultsPrefix": { "type": "string", "minLength": 1 },
        "resultNounSingular": { "type": "string", "minLength": 1 },
        "resultNounPlural": { "type": "string", "minLength": 1 }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slug",
        "title",
        "summary",
        "status",
        "year",
        "tags",
        "highlights",
        "links"
      ],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["featured", "live", "exploration"]
        },
        "year": { "type": "string", "minLength": 1 },
        "tags": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "highlights": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "links": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/link" }
        }
      }
    },
    "experienceEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "company",
        "role",
        "period",
        "location",
        "summary",
        "achievements"
      ],
      "properties": {
        "company": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "period": { "type": "string", "minLength": 1 },
        "location": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "achievements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "skillGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description", "items"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "interest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 }
      }
    },
    "homeSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "navLabel",
        "hero",
        "stats",
        "principlesIntro",
        "principles"
      ],
      "properties": {
        "id": { "const": "home" },
        "navLabel": { "type": "string", "minLength": 1 },
        "hero": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "eyebrow",
            "headline",
            "intro",
            "missionLabel",
            "mission",
            "availability",
            "primaryCta",
            "secondaryCta",
            "supportNote"
          ],
          "properties": {
            "eyebrow": { "type": "string", "minLength": 1 },
            "headline": { "type": "string", "minLength": 1 },
            "intro": { "type": "string", "minLength": 1 },
            "missionLabel": { "type": "string", "minLength": 1 },
            "mission": { "type": "string", "minLength": 1 },
            "availability": { "type": "string", "minLength": 1 },
            "primaryCta": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "href"],
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "href": { "type": "string", "minLength": 1 }
              }
            },
            "secondaryCta": {
              "type": "object",
              "additionalProperties": false,
              "required": ["label", "href"],
              "properties": {
                "label": { "type": "string", "minLength": 1 },
                "href": { "type": "string", "minLength": 1 }
              }
            },
            "supportNote": { "type": "string", "minLength": 1 }
          }
        },
        "stats": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/stat" }
        },
        "principlesIntro": { "$ref": "#/$defs/sectionHeading" },
        "principles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/principle" }
        }
      }
    },
    "projectsSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "navLabel",
        "intro",
        "homeCard",
        "interaction",
        "projects"
      ],
      "properties": {
        "id": { "const": "projects" },
        "enabled": { "type": "boolean" },
        "navLabel": { "type": "string", "minLength": 1 },
        "intro": { "$ref": "#/$defs/pageIntro" },
        "homeCard": { "$ref": "#/$defs/homeCard" },
        "interaction": { "$ref": "#/$defs/projectInteraction" },
        "projects": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/project" }
        }
      }
    },
    "experienceSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "navLabel",
        "intro",
        "homeCard",
        "timeline",
        "entries"
      ],
      "properties": {
        "id": { "const": "experience" },
        "enabled": { "type": "boolean" },
        "navLabel": { "type": "string", "minLength": 1 },
        "intro": { "$ref": "#/$defs/pageIntro" },
        "homeCard": { "$ref": "#/$defs/homeCard" },
        "timeline": {
          "type": "object",
          "additionalProperties": false,
          "required": ["eyebrow", "title", "description"],
          "properties": {
            "eyebrow": { "type": "string", "minLength": 1 },
            "title": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 1 }
          }
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/experienceEntry" }
        }
      }
    },
    "interestsSection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "navLabel",
        "intro",
        "homeCard",
        "skillsHeading",
        "skillGroups",
        "interestsHeading",
        "interests",
        "nowHeading",
        "now"
      ],
      "properties": {
        "id": { "const": "interests" },
        "enabled": { "type": "boolean" },
        "navLabel": { "type": "string", "minLength": 1 },
        "intro": { "$ref": "#/$defs/pageIntro" },
        "homeCard": { "$ref": "#/$defs/homeCard" },
        "skillsHeading": { "$ref": "#/$defs/sectionHeading" },
        "skillGroups": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skillGroup" }
        },
        "interestsHeading": { "$ref": "#/$defs/sectionHeading" },
        "interests": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/interest" }
        },
        "nowHeading": { "$ref": "#/$defs/sectionHeading" },
        "now": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
