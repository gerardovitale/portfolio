---
import PageIntro from "../components/PageIntro.astro";
import { siteData } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Interests"
  description="Technology stack, interests, and current areas of focus."
>
  <PageIntro
    eyebrow="Stack and Interests"
    title="The tools I use and the problems I keep returning to."
    description="This route ties together technical preference, delivery practice, and the subjects that keep shaping my approach to software."
  />

  <section class="section">
    <div class="shell grid grid-three">
      {
        siteData.skillGroups.map((group) => (
          <article class="card">
            <div class="card-body stack">
              <span class="eyebrow">{group.title}</span>
              <p class="muted">{group.description}</p>
              <div class="link-row">
                {group.items.map((item) => (
                  <span class="pill">{item}</span>
                ))}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="stack">
        <span class="eyebrow">Interests</span>
        <h2
          style="font-size: clamp(2rem, 5vw, 3.6rem); line-height: 1; margin: 0;"
        >
          What keeps my attention
        </h2>
      </div>
      <div class="stack">
        {
          siteData.interests.map((interest) => (
            <article class="card">
              <div class="card-body stack">
                <h3 style="margin: 0; font-size: 1.15rem;">{interest.title}</h3>
                <p class="muted">{interest.summary}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell split">
      <div class="stack">
        <span class="eyebrow">Now</span>
        <h2
          style="font-size: clamp(2rem, 5vw, 3.6rem); line-height: 1; margin: 0;"
        >
          Current focus
        </h2>
      </div>
      <div class="stack">
        {siteData.now.map((item) => <div class="surface-note">{item}</div>)}
      </div>
    </div>
  </section>
</BaseLayout>
