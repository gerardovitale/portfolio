---
import PageIntro from "../components/PageIntro.astro";
import { ProjectFilters } from "../components/ProjectFilters";
import { allProjectTags, siteData } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Projects"
  description="Technical projects and product delivery case studies."
>
  <PageIntro
    eyebrow="Technical Projects"
    title="Projects shaped for delivery, not just presentation."
    description="The strongest work here is not only about technical output. It is about clearer contracts, safer release paths, and interfaces that help users decide faster."
  />

  <section class="section">
    <div class="shell split">
      <div class="stack">
        <span class="eyebrow">Interaction</span>
        <h2
          style="font-size: clamp(2rem, 5vw, 3.6rem); line-height: 1; margin: 0;"
        >
          Filter the portfolio by intent.
        </h2>
        <p class="muted">
          The interactive layer on this route is client-side only. Content stays
          static at build time, and React is used only where state changes
          improve exploration.
        </p>
        <div class="link-row">
          {allProjectTags.map((tag) => <span class="pill">{tag}</span>)}
        </div>
      </div>

      <ProjectFilters client:load projects={siteData.projects} />
    </div>
  </section>
</BaseLayout>
