---
import SectionPage from "../../components/SectionPage.astro";
import { getSiteContext, isKnownPageSectionId } from "../../data/site";

export function getStaticPaths() {
  return getSiteContext("es").enabledPageSections.map((section) => ({
    params: { section: section.id },
  }));
}

const sectionParam = Astro.params.section;

if (!sectionParam || !isKnownPageSectionId(sectionParam)) {
  throw new Error(`Unknown section route: ${sectionParam ?? "missing"}`);
}
---

<SectionPage locale="es" sectionId={sectionParam} />
