---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import type { NavigationItem, SiteData } from "../data/site";
import { localizePath, type Locale } from "../lib/locale";
import {
  buildStructuredData,
  defaultSocialImageUrl,
  getAlternateLanguageUrls,
  getCanonicalUrl,
  getDefaultLanguageUrl,
  makePageTitle,
} from "../lib/meta";
import { getThemeInlineStyle } from "../data/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  locale: Locale;
  navigationItems: NavigationItem[];
  noindex?: boolean;
  showLocaleAlternates?: boolean;
  siteData: SiteData;
}

const {
  title,
  description = "Portfolio website for a data engineer focused on resilient systems.",
  locale,
  navigationItems,
  noindex = false,
  showLocaleAlternates = false,
  siteData,
} = Astro.props;
const pageTitle = makePageTitle(siteData, title);
const canonical = getCanonicalUrl(Astro.url.pathname);
const alternateLanguageUrls = showLocaleAlternates
  ? getAlternateLanguageUrls(Astro.url.pathname)
  : [];
const defaultLanguageUrl = showLocaleAlternates
  ? getDefaultLanguageUrl(Astro.url.pathname)
  : null;
const themeColor = siteData.theme.themeColor ?? siteData.theme.palette.accent;
const socialImageAlt = `${siteData.person.name} portfolio preview`;
const structuredData = buildStructuredData({
  siteData,
  title,
  description,
  pathname: Astro.url.pathname,
});
const themeInlineStyle = getThemeInlineStyle(siteData);
const openGraphLocale = locale === "es" ? "es_ES" : "en_US";
const localeSwitcherHref = showLocaleAlternates
  ? localizePath(Astro.url.pathname, locale === "en" ? "es" : "en")
  : undefined;
---

<!doctype html>
<html lang={locale} style={themeInlineStyle}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <script is:inline>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        document.documentElement.dataset.motion = "enabled";
      }
    </script>
    <meta
      name="robots"
      content={noindex ? "noindex, nofollow" : "index, follow"}
    />
    <link rel="canonical" href={canonical} />
    {
      alternateLanguageUrls.map((alternate) => (
        <link
          rel="alternate"
          hreflang={alternate.locale}
          href={alternate.href}
        />
      ))
    }
    {
      defaultLanguageUrl && (
        <link rel="alternate" hreflang="x-default" href={defaultLanguageUrl} />
      )
    }
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta property="og:site_name" content={siteData.person.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={openGraphLocale} />
    <meta property="og:image" content={defaultSocialImageUrl} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={defaultSocialImageUrl} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <meta name="theme-color" content={themeColor} />
    <script type="application/ld+json" is:inline set:html={structuredData} />
  </head>
  <body>
    <Header
      currentPath={Astro.url.pathname}
      locale={locale}
      localeSwitcherHref={localeSwitcherHref}
      navigationItems={navigationItems}
      siteData={siteData}
    />
    <main>
      <slot />
    </main>
    <Footer locale={locale} siteData={siteData} />
    <script is:inline>
      const motionRoot = document.documentElement;
      const motionBody = document.body;

      if (motionRoot.dataset.motion === "enabled" && motionBody) {
        const revealTargets = Array.from(
          document.querySelectorAll("[data-reveal]"),
        );
        const revealGroups = Array.from(
          document.querySelectorAll("[data-reveal-group]"),
        );

        const setRevealDelay = (element) => {
          if (!(element instanceof HTMLElement)) {
            return;
          }

          const rawDelay = element.dataset.revealDelay;

          if (!rawDelay) {
            return;
          }

          const delay = Number.parseInt(rawDelay, 10);

          if (Number.isFinite(delay)) {
            element.style.setProperty("--reveal-delay", `${delay}ms`);
          }
        };

        const markRevealed = (element) => {
          if (element instanceof HTMLElement) {
            element.classList.add("is-revealed");
          }
        };

        const isInitiallyVisible = (element) => {
          if (!(element instanceof HTMLElement)) {
            return false;
          }

          const { bottom, top } = element.getBoundingClientRect();

          return top <= window.innerHeight * 0.88 && bottom >= 0;
        };

        revealTargets.forEach((target) => {
          setRevealDelay(target);

          if (isInitiallyVisible(target)) {
            markRevealed(target);
          }
        });

        revealGroups.forEach((group) => {
          setRevealDelay(group);

          Array.from(group.children).forEach((child, index) => {
            if (!(child instanceof HTMLElement) || !child.dataset.revealItem) {
              return;
            }

            child.style.setProperty("--reveal-index", String(index));
          });

          if (isInitiallyVisible(group)) {
            markRevealed(group);
          }
        });

        motionBody.dataset.motionReady = "true";

        if ("IntersectionObserver" in window) {
          const revealObserver = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) {
                  return;
                }

                markRevealed(entry.target);
                revealObserver.unobserve(entry.target);
              });
            },
            {
              rootMargin: "0px 0px -12% 0px",
              threshold: 0.12,
            },
          );

          [...revealTargets, ...revealGroups].forEach((target) => {
            if (
              target instanceof HTMLElement &&
              !target.classList.contains("is-revealed")
            ) {
              revealObserver.observe(target);
            }
          });
        } else {
          [...revealTargets, ...revealGroups].forEach(markRevealed);
        }
      }
    </script>
  </body>
</html>
