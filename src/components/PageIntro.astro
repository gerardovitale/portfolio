---
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<section class="section route-anchor">
  <div class="shell stack">
    <span class="eyebrow">{eyebrow}</span>
    <h1 class="headline">{title}</h1>
    <p class="subheadline">{description}</p>
  </div>
</section>
