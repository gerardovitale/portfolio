---
import { normalizePath } from "../lib/routing";

const { currentPath = "/" } = Astro.props;
const normalizedCurrentPath = normalizePath(currentPath);

const navItems = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/experience", label: "Experience" },
  { href: "/interests", label: "Interests" },
];
---

<header class="header">
  <div class="shell header-inner">
    <a class="brand" href="/">
      <span class="brand-mark">GV</span>
      <span class="brand-copy">
        <strong>Gerardo Vitale</strong>
        <span>Data engineer</span>
      </span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "nav-link",
                  normalizedCurrentPath === item.href && "is-active",
                ]}
                aria-current={
                  normalizedCurrentPath === item.href ? "page" : undefined
                }
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    border-bottom: var(--line);
    background: rgba(247, 247, 245, 0.8);
  }

  .header-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .brand {
    display: inline-flex;
    gap: var(--space-3);
    align-items: center;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: var(--line);
    background: var(--color-bg-strong);
    letter-spacing: 0.08em;
    font-size: 0.8rem;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.1;
  }

  .brand-copy strong {
    font-size: 0.95rem;
    font-weight: 600;
  }

  .brand-copy span {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link {
    display: inline-flex;
    min-height: 2.6rem;
    align-items: center;
    padding: 0.7rem 0.9rem;
    border: var(--line);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.73rem;
    background: rgba(255, 255, 255, 0.48);
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-link:hover {
    transform: translateY(-1px);
    border-color: var(--color-border-strong);
  }

  .is-active {
    background: var(--color-accent);
    color: var(--color-inverse);
    border-color: var(--color-accent);
  }

  @media (min-width: 48rem) {
    .header-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
