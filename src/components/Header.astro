---
import type { NavigationItem, SiteData } from "../data/site";
import {
  getCloseNavigationMenuLabel,
  getAlternateLocale,
  getLocaleCode,
  getLanguageSwitcherLabel,
  getLocaleName,
  localizePath,
  getOpenNavigationMenuLabel,
  getPrimaryNavigationLabel,
  type Locale,
} from "../lib/locale";
import { normalizePath } from "../lib/routing";

interface Props {
  currentPath?: string;
  locale: Locale;
  localeSwitcherHref?: string;
  navigationItems: NavigationItem[];
  siteData: SiteData;
}

const {
  currentPath = "/",
  locale,
  localeSwitcherHref,
  navigationItems,
  siteData,
} = Astro.props;
const normalizedCurrentPath = normalizePath(currentPath);
const alternateLocale = getAlternateLocale(locale);
const localeSwitcherLabel = getLanguageSwitcherLabel(locale);
const navigationLabel = getPrimaryNavigationLabel(locale);
const openNavigationMenuLabel = getOpenNavigationMenuLabel(locale);
const closeNavigationMenuLabel = getCloseNavigationMenuLabel(locale);
const menuToggleId = `primary-navigation-toggle-${locale}`;
const mobileNavId = `primary-navigation-${locale}`;
const localizedHomePath = localizePath("/", locale);
---

<header class="header">
  <div class="shell header-inner">
    <a class="brand" href={navigationItems[0]?.href ?? "/"}>
      <span class="brand-mark">{siteData.person.brandMark}</span>
      <span class="brand-copy">
        <strong>{siteData.person.name}</strong>
        <span>{siteData.person.role}</span>
      </span>
    </a>

    <button
      type="button"
      id={menuToggleId}
      class="menu-toggle"
      data-mobile-nav-toggle
      aria-controls={mobileNavId}
      aria-expanded="false"
      aria-label={openNavigationMenuLabel}
      data-open-label={openNavigationMenuLabel}
      data-close-label={closeNavigationMenuLabel}
      hidden
    >
      <span class="menu-toggle-icon" aria-hidden="true">
        <span class="menu-toggle-line"></span>
        <span class="menu-toggle-line"></span>
        <span class="menu-toggle-line"></span>
      </span>
    </button>

    <nav
      id={mobileNavId}
      class="primary-nav"
      aria-label={navigationLabel}
      data-mobile-nav
      data-current-path={normalizedCurrentPath}
      data-home-path={normalizePath(localizedHomePath)}
    >
      <ul class="nav-list">
        {
          navigationItems.map((item) => (
            <li>
              <a
                href={item.href}
                data-section-link
                data-section-id={item.id}
                class="nav-link"
              >
                {item.label}
              </a>
            </li>
          ))
        }
        {
          localeSwitcherHref && (
            <li>
              <a
                class="locale-link"
                href={localeSwitcherHref}
                data-locale-switcher
                data-base-href={localeSwitcherHref}
                aria-label={`${localeSwitcherLabel}: ${getLocaleName(alternateLocale)}`}
              >
                {getLocaleCode(alternateLocale)}
              </a>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script is:inline>
  const menuToggle = document.querySelector("[data-mobile-nav-toggle]");
  const primaryNav = document.querySelector("[data-mobile-nav]");
  const sectionLinks = Array.from(
    document.querySelectorAll("[data-section-link]"),
  );
  const localeSwitcher = document.querySelector("[data-locale-switcher]");

  if (
    menuToggle instanceof HTMLButtonElement &&
    primaryNav instanceof HTMLElement
  ) {
    const desktopMediaQuery = window.matchMedia("(min-width: 48rem)");

    const setExpanded = (expanded) => {
      menuToggle.setAttribute("aria-expanded", String(expanded));
      menuToggle.setAttribute(
        "aria-label",
        expanded
          ? (menuToggle.dataset.closeLabel ?? "")
          : (menuToggle.dataset.openLabel ?? ""),
      );
      primaryNav.hidden = !expanded;
    };

    const syncNavigationVisibility = () => {
      menuToggle.hidden = false;

      if (desktopMediaQuery.matches) {
        menuToggle.setAttribute("aria-expanded", "false");
        menuToggle.setAttribute(
          "aria-label",
          menuToggle.dataset.openLabel ?? "",
        );
        primaryNav.hidden = false;
        return;
      }

      setExpanded(false);
    };

    menuToggle.addEventListener("click", () => {
      if (desktopMediaQuery.matches) {
        return;
      }

      setExpanded(menuToggle.getAttribute("aria-expanded") !== "true");
    });

    document.addEventListener("keydown", (event) => {
      if (
        event.key === "Escape" &&
        !desktopMediaQuery.matches &&
        menuToggle.getAttribute("aria-expanded") === "true"
      ) {
        setExpanded(false);
        menuToggle.focus();
      }
    });

    desktopMediaQuery.addEventListener("change", syncNavigationVisibility);
    syncNavigationVisibility();

    sectionLinks.forEach((link) => {
      link.addEventListener("click", () => {
        if (!desktopMediaQuery.matches) {
          setExpanded(false);
        }
      });
    });
  }

  if (sectionLinks.length > 0) {
    const currentPath = primaryNav?.dataset.currentPath ?? "";
    const homePath = primaryNav?.dataset.homePath ?? "";

    const getActiveSectionId = () => {
      const hash = window.location.hash.replace(/^#/, "");

      if (hash) {
        return hash;
      }

      return currentPath === homePath ? "home" : null;
    };

    const syncSectionLinks = () => {
      const activeSectionId = getActiveSectionId();

      sectionLinks.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) {
          return;
        }

        const isActive = link.dataset.sectionId === activeSectionId;
        link.classList.toggle("is-active", isActive);

        if (isActive) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    };

    window.addEventListener("hashchange", syncSectionLinks);
    syncSectionLinks();
  }

  if (localeSwitcher instanceof HTMLAnchorElement) {
    const syncLocaleSwitcherHref = () => {
      const hash = window.location.hash;
      const baseHref =
        localeSwitcher.dataset.baseHref ??
        localeSwitcher.getAttribute("href") ??
        localeSwitcher.href;

      localeSwitcher.setAttribute(
        "href",
        hash ? `${baseHref}${hash}` : baseHref,
      );
    };

    window.addEventListener("hashchange", syncLocaleSwitcherHref);
    syncLocaleSwitcherHref();
  }
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(22px);
    border-bottom: var(--line);
    background: color-mix(in srgb, var(--color-bg) 82%, transparent);
  }

  .header-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) 0;
  }

  .brand {
    display: inline-flex;
    gap: var(--space-3);
    align-items: center;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: var(--line);
    background: var(--color-surface);
    letter-spacing: 0.14em;
    font-size: 0.8rem;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.1;
  }

  .brand-copy strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .brand-copy span {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .primary-nav {
    grid-column: 1 / -1;
  }

  .menu-toggle {
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    padding: 0;
    border: var(--line);
    background: var(--color-bg-strong);
    cursor: pointer;
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .menu-toggle:hover {
    transform: translateY(-1px);
    border-color: var(--color-border-strong);
  }

  .menu-toggle-icon {
    display: grid;
    gap: 0.28rem;
  }

  .menu-toggle-line {
    display: block;
    width: 1.15rem;
    height: 1px;
    background: currentColor;
    transition:
      opacity var(--transition-fast),
      transform var(--transition-fast);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-line:first-child {
    transform: translateY(0.38rem) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-line:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle[aria-expanded="true"] .menu-toggle-line:last-child {
    transform: translateY(-0.38rem) rotate(-45deg);
  }

  .nav-list {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link,
  .locale-link {
    display: inline-flex;
    min-height: 2.6rem;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.9rem;
    border: 1px solid transparent;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    font-size: 0.7rem;
    background: transparent;
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-link {
    width: 100%;
    justify-content: flex-start;
    color: var(--color-text-muted);
  }

  .nav-link:hover,
  .locale-link:hover {
    transform: translateY(-1px);
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .locale-link {
    width: 2.6rem;
    min-width: 2.6rem;
    padding: 0;
    background: var(--color-surface);
    letter-spacing: 0.08em;
    font-weight: 700;
  }

  .is-active {
    background: var(--color-accent);
    color: var(--color-inverse);
    border-color: var(--color-accent);
  }

  @media (min-width: 48rem) {
    .header-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .menu-toggle {
      display: none;
    }

    .primary-nav {
      grid-column: auto;
    }

    .nav-list {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
    }

    .nav-link {
      width: auto;
      justify-content: center;
    }
  }
</style>
