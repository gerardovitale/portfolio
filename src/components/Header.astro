---
import type { NavigationItem, SiteData } from "../data/site";
import {
  getAlternateLocale,
  getLocaleCode,
  getLanguageSwitcherLabel,
  getLocaleName,
  getPrimaryNavigationLabel,
  type Locale,
} from "../lib/locale";
import { normalizePath } from "../lib/routing";

interface Props {
  currentPath?: string;
  locale: Locale;
  localeSwitcherHref?: string;
  navigationItems: NavigationItem[];
  siteData: SiteData;
}

const {
  currentPath = "/",
  locale,
  localeSwitcherHref,
  navigationItems,
  siteData,
} = Astro.props;
const normalizedCurrentPath = normalizePath(currentPath);
const alternateLocale = getAlternateLocale(locale);
const localeSwitcherLabel = getLanguageSwitcherLabel(locale);
const navigationLabel = getPrimaryNavigationLabel(locale);
---

<header class="header">
  <div class="shell header-inner">
    <a class="brand" href={navigationItems[0]?.href ?? "/"}>
      <span class="brand-mark">{siteData.person.brandMark}</span>
      <span class="brand-copy">
        <strong>{siteData.person.name}</strong>
        <span>{siteData.person.role}</span>
      </span>
    </a>

    <nav aria-label={navigationLabel}>
      <ul class="nav-list">
        {
          navigationItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "nav-link",
                  normalizedCurrentPath === item.href && "is-active",
                ]}
                aria-current={
                  normalizedCurrentPath === item.href ? "page" : undefined
                }
              >
                {item.label}
              </a>
            </li>
          ))
        }
        {
          localeSwitcherHref && (
            <li>
              <a
                class="locale-link"
                href={localeSwitcherHref}
                aria-label={`${localeSwitcherLabel}: ${getLocaleName(alternateLocale)}`}
              >
                {getLocaleCode(alternateLocale)}
              </a>
            </li>
          )
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
    border-bottom: var(--line);
    background: var(--color-bg);
  }

  .header-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-4) 0;
  }

  .brand {
    display: inline-flex;
    gap: var(--space-3);
    align-items: center;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border: var(--line);
    background: var(--color-bg-strong);
    letter-spacing: 0.08em;
    font-size: 0.8rem;
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    line-height: 1.1;
  }

  .brand-copy strong {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 600;
  }

  .brand-copy span {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .nav-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-link,
  .locale-link {
    display: inline-flex;
    min-height: 2.6rem;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 0.9rem;
    border: var(--line);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.73rem;
    background: var(--color-bg-strong);
    transition:
      border-color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-fast);
  }

  .nav-link:hover,
  .locale-link:hover {
    transform: translateY(-1px);
    border-color: var(--color-border-strong);
  }

  .locale-link {
    width: 2.6rem;
    min-width: 2.6rem;
    padding: 0;
    border-radius: 999px;
    background: var(--color-surface);
    letter-spacing: 0.04em;
    font-weight: 700;
  }

  .is-active {
    background: var(--color-accent);
    color: var(--color-inverse);
    border-color: var(--color-accent);
  }

  @media (min-width: 48rem) {
    .header-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
</style>
